# このファイルを .env にコピーして値を埋める（.env は絶対にコミットしない）

# 必須 ─────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# 任意（未設定ならデフォルト値）───────
# CLAUDE_MODEL=claude-sonnet-5        # コスト優先なら claude-haiku-4-5-20251001
# TOP_N=5                             # 選ぶニュース本数
# WINDOW_HOURS=24                     # 何時間前までの記事を対象にするか
# MAX_PER_FEED=15                     # 1フィードあたりの最大取得件数
# CLAUDE_LENS=...                     # 視点コメントの切り口（claude.js 参照）
# SITE_TITLE=朝のニュースダイジェスト  # サイト上部のタイトル
# KEEP_DAYS=30                        # サイトに残す過去日数
